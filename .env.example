# =============================================================================
# CCSHAU Website — Environment Variables (root reference)
# Copy apps/web/.env.example to apps/web/.env.local for local development
# =============================================================================

# --- Supabase (from Supabase Cloud project settings) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=CCSHAU Hisar

# --- Power Automate (server-side only — never NEXT_PUBLIC_) ---
POWER_AUTOMATE_EMAIL_URL=
POWER_AUTOMATE_WEBHOOK_SECRET=
ADMIN_ALERT_EMAIL=computer.section@hau.ac.in
POWER_AUTOMATE_TEST_EMAIL=

# --- Optional: separate flows ---
POWER_AUTOMATE_PASSWORD_RESET_URL=
POWER_AUTOMATE_LOCKOUT_ALERT_URL=

# --- CAPTCHA ---
NEXT_PUBLIC_CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=
